{
  "name": "p2p-market",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @p2p/api prisma:generate",
    "db:migrate": "pnpm --filter @p2p/api prisma:migrate",
    "db:seed": "pnpm --filter @p2p/api prisma:seed",
    "db:migrate:deploy": "pnpm --filter @p2p/api prisma:migrate:deploy"
  },
  "devDependencies": {
    "turbo": "^2.2.3",
    "typescript": "^5.6.3"
  }
}
