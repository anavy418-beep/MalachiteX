# Shared
NODE_ENV=development

# Database / cache
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/p2p_mvp?schema=public
REDIS_URL=redis://localhost:6379

# API
API_PORT=4000
JWT_ACCESS_SECRET=dev_access_secret_change_me_please_32_chars
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_please_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
PASSWORD_RESET_EXPIRES_MINUTES=15
SWAGGER_ENABLED=true
DEFAULT_FIAT_CURRENCY=INR
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
NEXT_PUBLIC_API_SOCKET_URL=http://localhost:4000

# Production overrides (examples)
# FRONTEND_URL=https://your-app.vercel.app
# CORS_ORIGIN=https://your-app.vercel.app
# COOKIE_SECURE=true
# COOKIE_SAME_SITE=none
# NEXT_PUBLIC_API_BASE_URL=https://your-api.railway.app/api
# NEXT_PUBLIC_API_SOCKET_URL=https://your-api.railway.app
